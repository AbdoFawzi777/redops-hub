rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Is the user authenticated?
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Is the document owned by the authenticated user?
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper: Is the authenticated user an admin?
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // --- Users Profiles Collection ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Owner can create their profile as Operator, but cannot escalate their own role
      allow create: if isOwner(userId) && request.resource.data.role == 'Operator';
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
      allow delete: if false; // prevent deleting profiles from client-side
    }

    // --- Vulnerabilities Collection ---
    match /vulnerabilities/{vulnId} {
      // Authenticated operators and admins can read vulnerabilities
      allow read: if isAuthenticated();
      
      // Operators can create and update vulnerabilities
      allow create: if isAuthenticated() && request.resource.data.operatorUid == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.operatorUid == request.auth.uid || 
        request.auth.token.email.endsWith('@redopshub.com') ||
        isAdmin()
      );
      
      // Prevent deleting vulnerabilities from client-side to preserve audit trail
      allow delete: if false;
    }

    // --- Security Logs Collection (Write-Only Audit Log, Admin Readable) ---
    match /security_logs/{logId} {
      allow create: if true; // anyone can append audit logs
      allow read: if isAdmin(); // only admins can read security audit logs
      allow update, delete: if false; // no one can delete/alter logs from client-side
    }

    // --- Operator Activity Logs Collection (Immutable Audit Log, Admin Readable) ---
    match /activity_logs/{logId} {
      allow create: if isAuthenticated(); // authenticated operators can write logs
      allow read: if isAdmin(); // only admins can read activity logs
      allow update, delete: if false; // immutable audit log
    }
  }
